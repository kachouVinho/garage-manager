{\n    "name": "garage-manager",\n    "description": "A Laravel project for managing a garage.",\n    "type": "project",\n    "require": {\n        "php": "^8.0",\n        "laravel/framework": "^9.0"\n    },\n    "autoload": {\n        "psr-4": {\n            "App\\": "app/"\n        }\n    },\n    "scripts": {\n        "post-autoload-dump": [\n            "Illuminate\Foundation\ComposerScripts::postAutoloadDump",\n            "php artisan package:discover --ansi"\n        ],\n        "post-update-cmd": [\n            "php artisan migrate --force"\n        ]\n    },\n    "minimum-stability": "stable",\n    "prefer-stable": true\n}